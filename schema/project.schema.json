{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meyse.github.io/verus-projects/schema/project.schema.json",
  "title": "Verus project",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "slug",
    "description",
    "longDescription",
    "category",
    "verusFeatures"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "maxLength": 60
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 220
    },
    "longDescription": {
      "type": "string",
      "minLength": 1,
      "maxLength": 10000
    },
    "category": {
      "type": "string",
      "enum": ["wallet", "app", "dashboard", "tool", "other"]
    },
    "repoUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "websiteUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "docsUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "maintainer": {
      "type": "string",
      "maxLength": 100
    },
    "verusFeatures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "VerusID",
          "Currencies",
          "DeFi",
          "Cross-chain",
          "Zero-knowledge privacy",
          "Marketplace",
          "Data",
          "PBaaS-chain",
          "Staking",
          "Mining"
        ]
      }
    }
  }
}
